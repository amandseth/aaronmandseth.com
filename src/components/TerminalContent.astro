---
interface Props {
	prompt?: string;
	command?: string;
}

const { prompt = "aaron@webhost:/website$", command } = Astro.props;
---

<>
	<div class="flex flex-col gap-0 sm:flex-row sm:gap-3">
		<span class="text-green-400">{prompt}</span>
		{command && <span>{command}</span>}
	</div>
	<slot />
</>
