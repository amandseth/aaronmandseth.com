---
import { Image } from "astro:assets";
import Pill from "./Pill.astro";

import avatarImage from "../images/avatar.png";
---

<section id="about" class="mx-4 pt-4 text-lg">
	<h1 class="my-4 hidden text-center text-3xl sm:block sm:mb-10">
		Aaron Mandseth - Full Stack Developer
	</h1>
	<h1 class="mb-8 text-center text-3xl sm:hidden">
		<p>Aaron Mandseth</p>
		<p>Full Stack Developer</p>
	</h1>
	<div class="grid gap-8 md:grid-cols-2 lg:gap-16">
		<div class="flex items-center justify-center">
			<div class="w-[50%] md:w-[75%] lg:w-[60%]">
				<Image
					src={avatarImage}
					alt="Avatar"
					class="lazy w-full"
					loading="eager"
				/>
			</div>
		</div>
		<div>
			<div>
				<h1 class="my-4 text-3xl">Hello!</h1>
				<p>
					I'm a full stack web developer based in Edmonton, Alberta.
					I'm most familiar with the following technologies:
				</p>
				<div class="my-6 flex flex-wrap gap-3">
					{
						[
							"C#",
							"ASP .NET Core & MVC",
							"Entity Framework Core",
							"SQL",
							"HTML & CSS",
							"JavaScript & TypeScript",
							"Bootstrap",
							"Tailwind",
						].map((item) => (
							<Pill class="bg-brand-highlight-darker text-brand-foreground">
								{item}
							</Pill>
						))
					}
				</div>
				<p>
					In my free time I'm enjoying learning new tools and
					frameworks such as React, Next.js, and Astro.
				</p>
			</div>
		</div>
	</div>
</section>
